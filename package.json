{
  "name": "claude-ticker",
  "version": "1.1.2",
  "description": "Status bar for Claude CLI — color-coded project labels, git branch, context %, rate limits, and cost in one glanceable line. Zero token cost, zero dependencies.",
  "type": "module",
  "bin": {
    "claude-ticker": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "preversion": "npm test",
    "version": "git add -A",
    "postversion": "git push && git push --tags && npm publish",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-cli",
    "anthropic",
    "cli",
    "status-bar",
    "statusbar",
    "statusline",
    "terminal",
    "customizable",
    "rate-limit",
    "context-window",
    "color-coding",
    "monitoring",
    "directory name",
    "directory color",
    "dir-name",
    "dir-color",
    "working directory",
    "workspace name",
    "workspace alias",
    "claude directory",
    "git branch",
    "live token",
    "live context",
    "realtime token",
    "realtime context",
    "developer-experience",
    "dx",
    "productivity",
    "multi-project"
  ],
  "preferGlobal": true,
  "author": "Deepak Jha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpkay-io/claude-ticker.git"
  },
  "bugs": {
    "url": "https://github.com/dpkay-io/claude-ticker/issues"
  },
  "homepage": "https://github.com/dpkay-io/claude-ticker#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
